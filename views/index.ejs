<!DOCTYPE html>
<html lang="es">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Sistema de Ventas</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="/style.css">

</head>

<body>


    <nav class="navbar navbar-expand-lg navbar-custom">

        <div class="container">

            <a class="navbar-brand" href="/">
                SistemaVentas
            </a>

            <button class="navbar-toggler bg-light" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">

                <span class="navbar-toggler-icon"></span>

            </button>

            <div class="collapse navbar-collapse" id="navbarNav">

                <ul class="navbar-nav ms-auto">

                    <li class="nav-item">

                        <a class="nav-link" href="/">
                            Inicio
                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link" href="/productosVista">
                            Productos
                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link" href="/agregarProducto">
                            Agregar
                        </a>

                    </li>

                </ul>

            </div>

        </div>

    </nav>


    <div class="container">

        <div class="hero">

            <h1>
                Sistema de Gestión de Ventas
            </h1>

            <p>
                Plataforma Full Stack desarrollada con Node.js, Express, MySQL, Sequelize y EJS.
            </p>

            <a href="/productosVista" class="btn btn-light btn-lg mt-3">
                Ver Productos
            </a>

        </div>

    </div>

    <div class="container mt-5">

        <div class="row">

            <div class="col-md-4">

                <div class="card-custom">

                    <h3 class="card-title">
                        Gestión de Productos
                    </h3>

                    <p class="card-text">
                        Administra los productos de la tienda de manera rápida y sencilla.
                    </p>

                </div>

            </div>

            <div class="col-md-4">

                <div class="card-custom">

                    <h3 class="card-title">
                        CRUD Completo
                    </h3>

                    <p class="card-text">
                        Agrega, edita, elimina y visualiza productos en tiempo real.
                    </p>

                </div>

            </div>

            <div class="col-md-4">

                <div class="card-custom">

                    <h3 class="card-title">
                        Base de Datos
                    </h3>

                    <p class="card-text">
                        Información almacenada en MySQL utilizando Sequelize ORM.
                    </p>

                </div>

            </div>

        </div>

    </div>

    <div class="footer">

        Sistema de Gestión de Ventas © 2026

    </div>

</body>

</html>